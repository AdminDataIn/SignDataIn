POSTGRES_DB=signature_service
POSTGRES_USER=signature_user
POSTGRES_PASSWORD=change-me-now
DATABASE_URL=postgresql://signature_user:change-me-now@db:5432/signature_service

DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=sign.datain.pro
DJANGO_CSRF_TRUSTED_ORIGINS=https://sign.datain.pro
DJANGO_TIME_ZONE=America/Bogota
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True

APP_DOMAIN=sign.datain.pro
APP_USE_HTTPS=True
SIGNATURE_PUBLIC_BASE_URL=https://sign.datain.pro

SIGNATURE_PROVIDER=zapsign
SIGNATURE_LOG_LEVEL=INFO

ZAPSIGN_API_TOKEN=replace-with-real-token
ZAPSIGN_ENVIRONMENT=production
ZAPSIGN_AUTH_MODE=assinaturaTela
ZAPSIGN_SEND_AUTOMATIC_EMAIL=True
ZAPSIGN_ENABLE_SELFIE_VALIDATION=False
ZAPSIGN_SELFIE_VALIDATION_TYPE=identity-verification
ZAPSIGN_WEBHOOK_SECRET=replace-with-real-secret
ZAPSIGN_WEBHOOK_HEADER=X-ZapSign-Secret
